{
  "name": "server-python-agent",
  "version": "1.0.0",
  "description": "Frida agent written in TypeScript",
  "private": true,
  "main": "agent/index.ts",
  "type": "module",
  "scripts": {
    "build": "frida-compile agent/index.ts -o ../src/freat_server/_agent.js -c",
    "watch": "frida-compile agent/index.ts -o ../src/freat_server/_agent.js -w",
    "build-rollup": "rollup -c",
    "watch-rollup": "nodemon --watch agent/ -e ts,c --exec \"npm run build-rollup\""
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/frida-gum": "^19.0.0",
    "@types/node": "^18.14.0",
    "nodemon": "^3.1.10",
    "rollup": "^4.52.5",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
