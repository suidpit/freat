{
  "name": "server-python-agent",
  "version": "1.0.0",
  "description": "Frida agent written in TypeScript",
  "private": true,
  "main": "agent/index.ts",
  "type": "module",
  "scripts": {
    "prepare": "npm run build",
    "build": "frida-compile agent/index.ts -o ../src/freat_server/_agent.js -c",
    "watch": "frida-compile agent/index.ts -o ../src/freat_server/_agent.js -w"
  },
  "devDependencies": {
    "@types/frida-gum": "^19.0.0",
    "@types/node": "^18.14.0"
  }
}
